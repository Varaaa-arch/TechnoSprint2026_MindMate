# MindMate Backend — copy to .env and fill in values
# cp .env.example .env

# App
APP_NAME=MindMate API
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage: auto | memory | supabase
# auto = Supabase when URL+key set, else in-memory
STORAGE_BACKEND=auto

# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret

# Set false only for local API testing without login
REQUIRE_AUTH=true

# AI providers
# Dapatkan key di: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your_openai_key_here
# Opsional — hanya jika pakai Anthropic Claude
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
