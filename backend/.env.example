# MindMate Backend — copy to .env and fill in values
# cp .env.example .env

# App
APP_NAME=MindMate API
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase (optional for now — in-memory store used until wired)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (optional — chat uses fallback until keys are set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
