# MindMate Backend — copy to .env and fill in values
# cp .env.example .env

# App
APP_NAME=MindMate API
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage: auto | memory | supabase
# auto = Supabase when URL+key set, else in-memory
STORAGE_BACKEND=auto

# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI providers (optional — chat uses fallback until keys are set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
